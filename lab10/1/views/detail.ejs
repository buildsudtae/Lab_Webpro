<!DOCTYPE html>
<html>
  <head>
    <title>Detail</title>

    <style>
      body {
        font-family: Arial;
        background: #f5f5f5;
      }

      .container {
        width: 400px;
        margin: 40px auto;
        background: white;
        padding: 20px;
        border-radius: 8px;
        box-shadow: 0 2px 5px rgba(0, 0, 0, 0.2);
      }

      img {
        width: 100%;
        border-radius: 5px;
      }

      .btn {
        display: inline-block;
        background: #1976d2;
        color: white;
        padding: 8px 15px;
        border-radius: 5px;
        text-decoration: none;
        margin-top: 10px;
      }
    </style>
  </head>

  <body>
    <div class="container">
      <h2><%= product.name %></h2>

      <img src="<%= product.image_url %>" />

      <p>Description : <%= product.description %></p>
      <p>Price : <%= product.price %></p>
      <p>Amount : <%= product.quantity %></p>

      <a class="btn" href="/products">Go Back</a>
    </div>
  </body>
</html>

<%- include("header") %>

<h1 class="mb-4">Users List</h1>

<table class="table table-bordered">
    <thead class="table-secondary">
        <tr>
            <th>ID</th>
            <th>First Name</th>
            <th>Last Name</th>
            <th>Username</th>
            <th>Email</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        <% data.forEach((item)=>{ %>
            <tr>
                <td><%= item.id %></td>
                <td><%= item.first_name %></td>
                <td><%= item.last_name %></td>
                <td><%= item.username %></td>
                <td><%= item.email %></td>
                <td>
                    <a href="/detail/<%= item.id %>" class="btn btn-dark btn-sm">
                        Detail
                    </a>
                </td>
            </tr>
        <% }); %>
    </tbody>
</table>

</body>
</html>


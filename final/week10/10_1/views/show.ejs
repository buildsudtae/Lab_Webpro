<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <style>
        *{
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        .container{
            display: flex;
            flex-direction: column;
            margin: auto;
            max-width: 1200px;
            width: 100%;
            height: auto;
            align-items: center;
        }

        .allcard{
            display: grid;
            grid-template-columns: repeat(4,1fr);
            gap: 10px;

        }

        .card{
            border: 1px solid rgb(135, 135, 135);
            border-radius: 5px;
            display: flex;
            flex-direction: column;
            text-align: center;
            justify-content: space-between;
            width: 250px;
        }

        p{
            margin: 5px;
        }
        .card img{
            width: 100%;
            height: 150px;
            object-fit: cover;
        }

        .detail{
            background-color: aqua;
            padding: 10px;
            margin: 10px;
            border-radius: 10px;
            
        }

        @media (max-width: 700px) {
            .allcard {
                grid-template-columns: repeat(2, 1fr);
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <h3>
            My Product
        </h3>
        <div class="allcard">
            <% data.forEach(item => { %>
                <div class="card">
                    <img src="<%= item.image%>" alt="<%= item.name%>">
                    <p><%= item.name%></p>
                    <p><%= item.description%></p>
                    <a href="/detail/<%= item.id%>" class="detail">Detail</a>
                </div>
            <% }); %>
        </div>
    </div>
</body>
</html>
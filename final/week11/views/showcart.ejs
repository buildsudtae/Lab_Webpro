<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Your Cart</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: sans-serif; }
        .container {
            max-width: 800px;
            margin: 40px auto;
            text-align: center;
        }
        .menu-bar { margin-bottom: 20px; }
        .menu-bar a { text-decoration: none; padding: 10px 20px; background: #ddd; color: black; border-radius: 5px; margin: 5px; }
        
        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }
        th, td {
            border: 1px solid #ccc;
            padding: 15px;
            text-align: center;
        }
        th { background-color: #f4f4f4; }
        img { width: 100px; height: auto; border-radius: 5px;}
        
        .total-row { font-size: 20px; font-weight: bold; background-color: #fffae6; }
        .clear-btn { background-color: #ff4d4d; color: white; text-decoration: none; padding: 10px 15px; border-radius: 5px; display: inline-block; margin-top: 20px;}
    </style>
</head>
<body>
    <div class="container">
        
        <div class="menu-bar">
            <a href="/">⬅️ Back to Menu</a>
        </div>

        <h2>🛒 My Shopping Cart</h2>

        <% if (message) { %>
            <h3 style="color: gray; margin-top: 30px;"><%= message %></h3>
        <% } else { %>
            
            <table>
                <thead>
                    <tr>
                        <th>Image</th>
                        <th>Product Name</th>
                        <th>Price</th>
                    </tr>
                </thead>
                <tbody>
                    <% let total = 0; %>
                    <% data.forEach(item => { %>
                        <tr>
                            <td><img src="<%= item.image %>" alt="<%= item.name %>"></td>
                            <td><%= item.name %></td>
                            <td>฿<%= item.price %></td>
                        </tr>
                        <% total += item.price; %>
                    <% }); %>
                    
                    <tr class="total-row">
                        <td colspan="2" style="text-align: right;">Total Price:</td>
                        <td style="color: red;">฿<%= total %></td>
                    </tr>
                </tbody>
            </table>

            <a href="/clearcart" class="clear-btn">🗑️ Clear Cart</a>

        <% } %>

    </div>
</body>
</html>